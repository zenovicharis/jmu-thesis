@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ex:   <http://example.org/coom#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

#################################################
# Domain/range consistency for composition
#################################################

ex:HasComponentRangeShape
  a sh:NodeShape ;
  sh:targetSubjectsOf ex:hasComponent ;

  sh:property [
    sh:path ex:hasComponent ;
    sh:class ex:Component ;
    sh:message "hasComponent must reference a Component." ;
  ] .

#################################################
# Parameter values must be typed
#################################################

ex:ParameterValueShape
  a sh:NodeShape ;
  sh:targetClass ex:Parameter ;

  sh:property [
    sh:path ex:hasValue ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "Each parameter must have a typed value." ;
  ] .

#################################################
# Prevent structurally invalid self-links
#################################################

ex:NoSelfContainmentShape
  a sh:NodeShape ;
  sh:targetClass ex:Component ;

  sh:not [
    sh:property [
      sh:path ex:hasComponent ;
      sh:hasValue sh:this ;
    ]
  ] ;
  sh:message "A component must not contain itself." .
